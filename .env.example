# LLM - set one of these (or use Ollama / Cursor-native for no API keys)
# GEMINI_API_KEY=...     # Free at ai.google.dev
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# No keys needed for: Ollama (ollama pull llama3) or Cursor-native (--search-only + Cursor AI)

# Optional: Serper for richer news search (2,500 free/month). Adds Google News to topic search.
# SERPER_API_KEY=...

# Optional: YouTube API — fallback when DuckDuckGo is rate-limited (viral videos)
# YOUTUBE_API_KEY=...

# Optional: protect /api/refresh-daily from unauthorized calls (cron jobs add ?key=CRON_SECRET)
# CRON_SECRET=your-secret
