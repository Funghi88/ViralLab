# LLM - set one of these (or use Ollama / Cursor-native for no API keys)
# GEMINI_API_KEY=...     # Free at ai.google.dev
OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...

# No keys needed for: Ollama (ollama pull llama3) or Cursor-native (--search-only + Cursor AI)

# Optional: Serper for richer news search (2,500 free/month). Adds Google News to topic search.
# SERPER_API_KEY=...

# Optional: YouTube API — fallback when DuckDuckGo is rate-limited (viral videos)
# YOUTUBE_API_KEY=...

# Optional: protect /api/refresh-daily from unauthorized calls (cron jobs add ?key=CRON_SECRET)
# CRON_SECRET=your-secret

# Daily News — freshness (server.py)
# DAILY_REFRESH_INTERVAL_MINUTES=30   # APScheduler: how often to run scripts/daily_news.py (10–180, default 30)
# DAILY_AUTO_REFRESH_IF_OLDER_THAN_HOURS=8   # If daily_news_updated.txt is older, /daily triggers a debounced background refresh (0=disable)
# DAILY_AUTO_REFRESH_DEBOUNCE_SEC=2700   # Min seconds between stale-triggered refreshes (default 45 min)
# DAILY_REFRESH_TIMEOUT_SEC=420   # Subprocess timeout for daily_news.py
#
# After each successful daily digest, delete stale generated files in output/ (by mtime).
# OUTPUT_RETENTION_DAYS=3   # raw_*.md, digest_*, videos_*, transcript_*, article_rewrite_* older than this are removed
# OUTPUT_CLEANUP=1   # Set 0 to disable
# NEWS_VIDEOS_LONGFORM_REFRESH_MINUTES=60   # Interval for topic news, viral videos, longform jobs
# NEWS_TOPIC_SEARCH_TIMEOUT_SEC=180   # Background /api/search-news subprocess (multi-source zh can be slow; min 60, max 600)
# LONGFORM_SKIP_STARTUP_REFRESH=1   # Do not queue RSS refresh for /longform on server start (default: refresh in background)
# NEWS_REFRESH_MAX_TOPICS=15   # /news/refresh: max unique hot-tag searches (5–40, deduped by file stem)
#
# Background scheduler (daily digest, topic news + hot list, viral videos, longform RSS):
# Runs when you use ``python server.py``, or gunicorn/uvicorn (detected via SERVER_SOFTWARE), or on first HTTP request.
# VIRALLAB_DISABLE_SCHEDULER=1   # Turn off all interval jobs (use external cron only)
# CHINA_SCHEDULED_CRAWL_MINUTES=1440   # Optional: scheduled B站+知乎「热门」crawl (min 60; 1440 = once/day). Default 0 = off.

# Optional: publish webhooks for /publish queue
# X_PUBLISH_WEBHOOK=https://your-automation-endpoint.example/x
# BLOG_PUBLISH_WEBHOOK=https://your-automation-endpoint.example/blog

# Optional: yt-dlp browser cookies when Douyin / Xiaohongshu download is login-gated (same as Douyin)
# YTDLP_COOKIES_BROWSER=chrome
# YTDLP_COOKIES_PROFILE=Default
#
# Quick Queue + gost (same path as Cursor http.proxy): use the STABLE local HTTP front, not QuickQ's ephemeral port.
# Cursor stays on 127.0.0.1:18080; qq-http-bridge.sh restarts gost when QuickQ's upstream port changes.
# Uncomment so this app's process (and subprocesses that keep HTTP_PROXY) match Cursor:
# HTTP_PROXY=http://127.0.0.1:18080
# HTTPS_PROXY=http://127.0.0.1:18080
# BILIBILI_PROXY=http://127.0.0.1:18080
# Prefer leaving ALL_PROXY unset for Python unless you need SOCKS; mixed env can break requests without PySocks.
#
# Video-to-text: retries short links without env proxy if the proxy connection fails, and strips proxy for
# videocaptioner/yt-dlp like Bilibili fetch — still set 18080 above so news/search and other paths stay aligned.
#
# Optional WhisperX ASR (pip install -r requirements-asr.txt)
# VIRALLAB_ASR_ENGINE=auto          # auto | whisperx | videocaptioner
# VIRALLAB_WHISPER_MODEL=           # e.g. large-v3, medium (unset: see VIRALLAB_WHISPER_MAX_ACCURACY on CPU)
# VIRALLAB_WHISPER_MAX_ACCURACY=1   # 1 (default): large-v3 on CPU when model unset; 0: medium on CPU
# VIRALLAB_WHISPER_DEVICE=auto      # auto | cpu | cuda | mps
# VIRALLAB_WHISPER_BATCH_SIZE=8
# VIRALLAB_WHISPER_LOG=1            # 1 (default): one [whisperx] model=... line on stderr; 0 to silence
# VIRALLAB_WHISPER_VAD_METHOD=pyannote   # pyannote | silero (WhisperX 3.2+)
# VIRALLAB_WHISPER_CHUNK_SIZE=30
# VIRALLAB_WHISPER_VAD_ONSET=0.5
# VIRALLAB_WHISPER_VAD_OFFSET=0.363
# VIRALLAB_WHISPER_THREADS=4
# VIRALLAB_WHISPER_ASR_OPTIONS_JSON={"beam_size":5}
# VIRALLAB_HF_TOKEN=                # Hugging Face token for gated pyannote models (or use HF_TOKEN)
# VIRALLAB_FFMPEG_AF_PRESET=none    # none | speech_band_limit (highpass+lowpass for speech-heavy audio)
